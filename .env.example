# ================================
# Sistema Oxford - Environment Variables
# ================================
# Copy this file to .env and fill in the values
# NEVER commit .env to version control

# === DATABASE ===
POSTGRES_DB=oxford_db
POSTGRES_USER=oxford_user
POSTGRES_PASSWORD=your_secure_password_here

# === SYMFONY ===
APP_ENV=prod
APP_SECRET=generate_32_char_secret_here
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@database:5432/${POSTGRES_DB}?serverVersion=16&charset=utf8

# === CORPOSISTEMAS API ===
CORPOSISTEMAS_API_URL=https://api.corposistemas.gt
CORPOSISTEMAS_API_KEY=your_api_key_here
CORPOSISTEMAS_NIT=your_nit_here

# === JWT AUTHENTICATION ===
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=your_jwt_passphrase_here
JWT_TOKEN_TTL=3600
JWT_REFRESH_TOKEN_TTL=2592000

# === SECURITY ===
CORS_ALLOW_ORIGIN=^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$
TRUSTED_PROXIES=127.0.0.1,REMOTE_ADDR
TRUSTED_HOSTS='^(localhost|127\.0\.0\.1)$'

# === AI SERVICE ===
AI_SERVICE_URL=http://ai_service:8001
OPENAI_API_KEY=your_openai_key_here

# === RATE LIMITING ===
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_API=100/minute
