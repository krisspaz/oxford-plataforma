# ===========================================
# Sistema Oxford - Root Environment Template
# ===========================================
# Copy to .env.local and configure
# DO NOT commit .env.local!

# Database
POSTGRES_DB=oxford_db
POSTGRES_USER=oxford_user
POSTGRES_PASSWORD=CHANGE_ME_SECURE_PASSWORD_32_CHARS

# Application
APP_ENV=production
APP_SECRET=CHANGE_ME_SECRET_KEY_64_HEX_CHARS

# Ngrok (development only)
# NGROK_AUTHTOKEN=your_ngrok_token_here

# MinIO Object Storage
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_PASSWORD_24_CHARS

# MongoDB
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=CHANGE_ME_MONGO_PASSWORD_24_CHARS

# AI Service
AI_INTERNAL_KEY=CHANGE_ME_AI_KEY

# Logging
LOG_LEVEL=INFO
