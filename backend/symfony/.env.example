# Sistema Oxford - Environment Configuration Template
# ===================================================
# COPY THIS FILE to .env.local and configure your values
# DO NOT commit .env.local to version control!
#
# Security checklist before production:
# 1. Generate new APP_SECRET: php -r "echo bin2hex(random_bytes(16));"
# 2. Generate new JWT keys: php bin/console lexik:jwt:generate-keypair
# 3. Set strong JWT_PASSPHRASE (min 32 chars)
# 4. Generate new MERCURE_JWT_SECRET: php -r "echo bin2hex(random_bytes(32));"
# 5. Configure production DATABASE_URL
# 6. Restrict CORS_ALLOW_ORIGIN to your domain

###> symfony/framework-bundle ###
APP_ENV=prod
# REQUIRED: Generate with: php -r "echo bin2hex(random_bytes(16));"
APP_SECRET=CHANGE_ME_GENERATE_32_CHAR_HEX
APP_SHARE_DIR=var/share
###< symfony/framework-bundle ###

###> symfony/routing ###
DEFAULT_URI=https://your-domain.com
###< symfony/routing ###

###> doctrine/doctrine-bundle ###
# For production use PostgreSQL or MySQL:
# DATABASE_URL="postgresql://user:password@localhost:5432/oxford?serverVersion=15&charset=utf8"
# DATABASE_URL="mysql://user:password@localhost:3306/oxford?serverVersion=8.0&charset=utf8mb4"
DATABASE_URL="sqlite:///%kernel.project_dir%/var/data.db"
###< doctrine/doctrine-bundle ###

###> nelmio/cors-bundle ###
# IMPORTANT: Restrict to your production domain only
CORS_ALLOW_ORIGIN='^https://your-domain\.com$'
###< nelmio/cors-bundle ###

###> lexik/jwt-authentication-bundle ###
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
# REQUIRED: Use strong passphrase (min 32 chars)
JWT_PASSPHRASE=CHANGE_ME_USE_STRONG_PASSPHRASE_32_CHARS
###< lexik/jwt-authentication-bundle ###

###> symfony/lock ###
LOCK_DSN=flock
###< symfony/lock ###

TRUSTED_PROXIES=127.0.0.1

###> symfony/messenger ###
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
###< symfony/messenger ###

###> symfony/mercure-bundle ###
MERCURE_URL=http://mercure/.well-known/mercure
MERCURE_PUBLIC_URL=https://your-domain.com/.well-known/mercure
# REQUIRED: Generate with: php -r "echo bin2hex(random_bytes(32));"
MERCURE_JWT_SECRET=CHANGE_ME_GENERATE_64_CHAR_HEX
###< symfony/mercure-bundle ###

# Redis (optional)
REDIS_HOST=localhost
REDIS_PORT=6379
