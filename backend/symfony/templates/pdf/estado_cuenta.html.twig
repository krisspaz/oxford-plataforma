<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: Arial, sans-serif; font-size: 10pt; padding: 20px; }
        .header { text-align: center; border-bottom: 2px solid #0d9488; padding-bottom: 15px; margin-bottom: 20px; }
        .logo { font-size: 24pt; font-weight: bold; color: #0d9488; }
        .subtitle { font-size: 14pt; color: #666; margin-top: 5px; }
        .student-info { background: #f3f4f6; padding: 15px; border-radius: 8px; margin-bottom: 20px; display: flex; justify-content: space-between; }
        .student-name { font-size: 14pt; font-weight: bold; color: #1f2937; }
        .student-detail { font-size: 10pt; color: #6b7280; margin-top: 5px; }
        .balance-box { text-align: right; }
        .balance-label { font-size: 10pt; color: #6b7280; }
        .balance-amount { font-size: 20pt; font-weight: bold; }
        .balance-amount.positive { color: #dc2626; }
        .balance-amount.zero { color: #059669; }
        table { width: 100%; border-collapse: collapse; margin-bottom: 20px; }
        th { background: #0d9488; color: white; padding: 10px; text-align: left; font-size: 9pt; }
        td { padding: 8px 10px; border-bottom: 1px solid #e5e7eb; font-size: 9pt; }
        tr:nth-child(even) { background: #f9fafb; }
        .section-title { font-size: 12pt; font-weight: bold; color: #374151; margin: 20px 0 10px 0; padding-bottom: 5px; border-bottom: 1px solid #e5e7eb; }
        .status { padding: 2px 8px; border-radius: 10px; font-size: 8pt; font-weight: bold; }
        .status.pagado { background: #d1fae5; color: #059669; }
        .status.pendiente { background: #fef3c7; color: #d97706; }
        .status.vencido { background: #fee2e2; color: #dc2626; }
        .amount { text-align: right; font-family: monospace; }
        .footer { margin-top: 30px; text-align: center; font-size: 8pt; color: #9ca3af; }
        .totals { background: #f3f4f6; padding: 15px; border-radius: 8px; margin-top: 20px; }
        .totals-row { display: flex; justify-content: space-between; margin-bottom: 5px; }
        .totals-label { color: #6b7280; }
        .totals-value { font-weight: bold; font-family: monospace; }
    </style>
</head>
<body>
    <div class="header">
        <div class="logo">COLEGIO OXFORD</div>
        <div class="subtitle">Estado de Cuenta</div>
    </div>

    <div class="student-info">
        <div>
            <div class="student-name">{{ student.firstName }} {{ student.lastName }}</div>
            <div class="student-detail">Carnet: {{ student.carnet }}</div>
            <div class="student-detail">Fecha: {{ date|date('d/m/Y') }}</div>
        </div>
        <div class="balance-box">
            <div class="balance-label">Saldo Pendiente</div>
            {% set totalPending = 0 %}
            {% for quota in quotas %}
                {% if quota.status != 'PAGADO' %}
                    {% set totalPending = totalPending + (quota.amount - quota.paidAmount) %}
                {% endif %}
            {% endfor %}
            <div class="balance-amount {{ totalPending > 0 ? 'positive' : 'zero' }}">
                Q {{ totalPending|number_format(2, '.', ',') }}
            </div>
        </div>
    </div>

    <div class="section-title">Cuotas Asignadas</div>
    <table>
        <thead>
            <tr>
                <th>Concepto</th>
                <th>Vencimiento</th>
                <th style="text-align: right;">Monto</th>
                <th style="text-align: right;">Pagado</th>
                <th style="text-align: right;">Pendiente</th>
                <th>Estado</th>
            </tr>
        </thead>
        <tbody>
            {% for quota in quotas %}
            <tr>
                <td>{{ quota.concept }}</td>
                <td>{{ quota.dueDate|date('d/m/Y') }}</td>
                <td class="amount">Q {{ quota.amount|number_format(2, '.', ',') }}</td>
                <td class="amount">Q {{ quota.paidAmount|number_format(2, '.', ',') }}</td>
                <td class="amount">Q {{ (quota.amount - quota.paidAmount)|number_format(2, '.', ',') }}</td>
                <td><span class="status {{ quota.status|lower }}">{{ quota.status }}</span></td>
            </tr>
            {% endfor %}
        </tbody>
    </table>

    <div class="section-title">Historial de Pagos</div>
    <table>
        <thead>
            <tr>
                <th>Fecha</th>
                <th>Concepto</th>
                <th>Método</th>
                <th>Documento</th>
                <th style="text-align: right;">Monto</th>
            </tr>
        </thead>
        <tbody>
            {% for payment in payments %}
            <tr>
                <td>{{ payment.date|date('d/m/Y') }}</td>
                <td>{{ payment.concept }}</td>
                <td>{{ payment.method }}</td>
                <td>{{ payment.documentNumber ?? '-' }}</td>
                <td class="amount">Q {{ payment.amount|number_format(2, '.', ',') }}</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>

    <div class="totals">
        {% set totalAssigned = 0 %}
        {% set totalPaid = 0 %}
        {% for quota in quotas %}
            {% set totalAssigned = totalAssigned + quota.amount %}
            {% set totalPaid = totalPaid + quota.paidAmount %}
        {% endfor %}
        <div class="totals-row">
            <span class="totals-label">Total Asignado:</span>
            <span class="totals-value">Q {{ totalAssigned|number_format(2, '.', ',') }}</span>
        </div>
        <div class="totals-row">
            <span class="totals-label">Total Pagado:</span>
            <span class="totals-value" style="color: #059669;">Q {{ totalPaid|number_format(2, '.', ',') }}</span>
        </div>
        <div class="totals-row">
            <span class="totals-label">Saldo Pendiente:</span>
            <span class="totals-value" style="color: #dc2626;">Q {{ (totalAssigned - totalPaid)|number_format(2, '.', ',') }}</span>
        </div>
    </div>

    <div class="footer">
        <p>Documento generado el {{ date|date('d/m/Y H:i') }}</p>
        <p>Este documento es informativo y no constituye un recibo oficial de pago.</p>
    </div>
</body>
</html>
