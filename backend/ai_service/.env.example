# ===========================================
# Sistema Oxford - AI Service Environment Template
# ===========================================
# COPY to .env.local and configure ALL values
# DO NOT commit .env.local!
# ===========================================

# Application
# REQUIRED: Generate with: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_SECRET_KEY_64_HEX_CHARS
ALGORITHM=HS256
DEBUG=false
LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=8001

# MongoDB
# REQUIRED: Use real credentials
MONGO_URI=mongodb://admin:CHANGE_ME_MONGO_PASSWORD@mongodb:27017/
MONGO_DB=oxford_ai

# MinIO Object Storage
MINIO_ENDPOINT=minio:9000
MINIO_ROOT_USER=CHANGE_ME_MINIO_USER
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_PASSWORD_24_CHARS
MINIO_BUCKET=oxford-storage
MINIO_SECURE=false

# ChromaDB (Vector Store)
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# OpenAI (optional, for embeddings)
# OPENAI_API_KEY=sk-your-key-here

# Sentry (optional, for error tracking)
# SENTRY_DSN=https://your-sentry-dsn
