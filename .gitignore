# ===========================================
# Sistema Oxford - Git Ignore Configuration
# ===========================================

# === ENVIRONMENT FILES (CRITICAL) ===
.env
.env.local
.env.*.local
!.env.example
!*.env.example

# Generated secrets (NEVER commit)
.env.generated

# === JWT KEYS (CRITICAL) ===
backend/symfony/config/jwt/*.pem
!backend/symfony/config/jwt/.gitkeep

# === LOGS ===
*.log
logs/

# === OS FILES ===
.DS_Store
Thumbs.db
*.swp
*~

# === IDE ===
.idea/
.vscode/
.fleet/
.nova/
.zed/
*.sublime-*
.phpactor.json

# === NODE ===
node_modules/
.pnpm-store/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# === PHP ===
vendor/
.php-cs-fixer.cache
.phpunit.cache/
.phpunit.result.cache
auth.json
Homestead.json
Homestead.yaml

# === SYMFONY ===
var/cache/
var/log/
var/sessions/
public/bundles/
public/build/
public/storage/
storage/*.key

# === PYTHON ===
__pycache__/
*.py[cod]
*$py.class
.Python
venv/
.venv/
*.egg-info/

# === BUILD ARTIFACTS ===
dist/
build/
*.map

# === DUPLICATE FOLDERS ===
*\ [0-9]/
*\ 2/
*\ 3/
*\ 4/
*_backup/
*.backup

# === TESTING ===
coverage/
.nyc_output/
*.lcov

# === MISC ===
.direnv/
*.db
*.sqlite
!*.db.example
