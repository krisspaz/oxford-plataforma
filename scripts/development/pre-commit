#!/bin/sh
# Pre-commit hook for code quality checks
# Copy this file to .git/hooks/pre-commit and make executable:
# cp scripts/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit

echo "🔍 Running pre-commit checks..."

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Track if any checks fail
FAILED=0

# ========================================
# Frontend Checks
# ========================================

# Check if there are frontend changes
if git diff --cached --name-only | grep -q "^frontend/"; then
    echo "📦 Checking frontend..."

    # Run ESLint on staged files
    FRONTEND_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep "^frontend/.*\.\(js\|jsx\|ts\|tsx\)$" | sed 's|^frontend/||')
    
    if [ -n "$FRONTEND_FILES" ]; then
        echo "  Running ESLint..."
        cd frontend
        echo "$FRONTEND_FILES" | xargs npx eslint --max-warnings 0
        if [ $? -ne 0 ]; then
            echo "${RED}❌ ESLint failed${NC}"
            FAILED=1
        else
            echo "${GREEN}✓ ESLint passed${NC}"
        fi
        cd ..
    fi

    # Run Prettier check (don't fix, just check)
    if [ -n "$FRONTEND_FILES" ]; then
        echo "  Running Prettier check..."
        cd frontend
        echo "$FRONTEND_FILES" | xargs npx prettier --check
        if [ $? -ne 0 ]; then
            echo "${YELLOW}⚠️ Prettier issues found. Run 'npm run format' to fix.${NC}"
            # Warning only, don't fail
        else
            echo "${GREEN}✓ Prettier passed${NC}"
        fi
        cd ..
    fi
fi

# ========================================
# Backend PHP Checks
# ========================================

if git diff --cached --name-only | grep -q "^backend/symfony/"; then
    echo "🐘 Checking PHP backend..."
    
    PHP_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep "^backend/symfony/.*\.php$")
    
    if [ -n "$PHP_FILES" ]; then
        # PHP syntax check
        echo "  Running PHP syntax check..."
        for file in $PHP_FILES; do
            php -l "$file" > /dev/null 2>&1
            if [ $? -ne 0 ]; then
                echo "${RED}❌ PHP syntax error in $file${NC}"
                FAILED=1
            fi
        done
        
        if [ $FAILED -eq 0 ]; then
            echo "${GREEN}✓ PHP syntax passed${NC}"
        fi
    fi
fi

# ========================================
# Python AI Service Checks
# ========================================

if git diff --cached --name-only | grep -q "^backend/ai_service/"; then
    echo "🐍 Checking Python AI service..."
    
    PY_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep "^backend/ai_service/.*\.py$")
    
    if [ -n "$PY_FILES" ]; then
        # Python syntax check
        echo "  Running Python syntax check..."
        for file in $PY_FILES; do
            python3 -m py_compile "$file" 2>/dev/null
            if [ $? -ne 0 ]; then
                echo "${RED}❌ Python syntax error in $file${NC}"
                FAILED=1
            fi
        done
        
        if [ $FAILED -eq 0 ]; then
            echo "${GREEN}✓ Python syntax passed${NC}"
        fi
    fi
fi

# ========================================
# Security Checks
# ========================================

echo "🔒 Running security checks..."

# Check for sensitive data in commits
SENSITIVE_PATTERNS="password=|secret=|api_key=|AWS_|PRIVATE_KEY"
if git diff --cached | grep -iE "$SENSITIVE_PATTERNS" | grep -v "\.example\|\.md\|test"; then
    echo "${YELLOW}⚠️ Warning: Possible sensitive data detected. Please review.${NC}"
fi

# Check for debug statements
DEBUG_PATTERNS="console\.log|var_dump|print_r|dd\(|dump\("
DEBUG_FOUND=$(git diff --cached --name-only --diff-filter=ACM | xargs grep -l -E "$DEBUG_PATTERNS" 2>/dev/null | grep -v "test\|spec\|\.md")
if [ -n "$DEBUG_FOUND" ]; then
    echo "${YELLOW}⚠️ Debug statements found in: $DEBUG_FOUND${NC}"
fi

# ========================================
# Final Result
# ========================================

if [ $FAILED -ne 0 ]; then
    echo ""
    echo "${RED}❌ Pre-commit checks failed. Please fix the issues above.${NC}"
    exit 1
fi

echo ""
echo "${GREEN}✅ All pre-commit checks passed!${NC}"
exit 0
